# Copy to .env and fill in values. Never commit .env.
# Processor Worker secrets (set via `wrangler secret put`, not this file)
#   PROCESSOR_KEYPAIR=<base58-encoded 64-byte ed25519 keypair>
#   SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
#   GAME_ID=your-1upmonster-game-id

# Client environment (can be passed as --flags or env vars)
RPS_PROGRAM_ID=<deployed program ID>
RPS_GAME_ID=<your 1upmonster game ID>
PLATFORM_API_URL=https://api.1up.monster
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
